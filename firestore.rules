rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 150
        && request.resource.data.role in ['user', 'admin'];
      allow update: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.email == resource.data.email // Email is immutable
        && request.resource.data.role == resource.data.role;  // User cannot self-elevate role
      allow delete: if false; // Block user deletion except via admin controls (handled separately)
    }

    // --- Tasks Collection ---
    match /tasks/{taskId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.category is string
        && request.resource.data.priority in ['low', 'medium', 'high']
        && request.resource.data.status in ['todo', 'in_progress', 'completed'];
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.priority in ['low', 'medium', 'high']
        && request.resource.data.status in ['todo', 'in_progress', 'completed'];
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Goals Collection ---
    match /goals/{goalId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.type in ['daily', 'weekly', 'monthly', 'yearly']
        && request.resource.data.current is number
        && request.resource.data.target is number;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.current is number
        && request.resource.data.target is number;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Notes Collection ---
    match /notes/{noteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.content is string;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.content is string;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Expenses Collection ---
    match /expenses/{expenseId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.amount is number
        && request.resource.data.type in ['income', 'expense']
        && request.resource.data.category is string;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.amount is number
        && request.resource.data.type in ['income', 'expense']
        && request.resource.data.category is string;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Birthdays Collection ---
    match /birthdays/{birthdayId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.date is string;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.date is string;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Medicines Collection ---
    match /medicines/{medicineId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.dose is string
        && request.resource.data.time is string;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.dose is string
        && request.resource.data.time is string;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Shopping Collection ---
    match /shopping/{itemId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.category is string
        && request.resource.data.quantity is number
        && request.resource.data.purchased is bool;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.category is string
        && request.resource.data.quantity is number
        && request.resource.data.purchased is bool;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Settings Collection ---
    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == userId
        && request.resource.data.darkMode is bool
        && request.resource.data.language in ['en', 'si'];
      allow delete: if isOwner(userId);
    }
  }
}
